# Twitter API v2 credentials
# Get these from https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret

# Telegram Bot
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Base Chain RPC
# Free RPCs: https://chainlist.org/chain/8453
BASE_RPC_URL=https://mainnet.base.org

# Optional: Basescan API key for contract verification info
BASESCAN_API_KEY=your_basescan_api_key

# Influence score threshold (0-100). Only alert if score >= this value.
INFLUENCE_THRESHOLD=40
