# Twitter credentials (OPTIONAL — only needed if free GuestClient gets rate-limited)
# The bot uses twikit's free GuestClient by default (no API key, $0 cost).
# Only fill these in if you experience rate limiting issues.
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# Telegram Bot
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Base Chain RPC
# Free RPCs: https://chainlist.org/chain/8453
BASE_RPC_URL=https://mainnet.base.org

# Optional: Basescan API key for contract verification info
BASESCAN_API_KEY=your_basescan_api_key

# Influence score threshold (0-100). Only alert if score >= this value.
INFLUENCE_THRESHOLD=40

# Web dashboard port (default 8000)
WEB_PORT=8000
